{
  "name": "ngx-multi-level-push-menu",
  "version": "0.0.0-development",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiz4/ngx-multi-level-push-menu.git"
  },
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=20.19 <25",
    "npm": ">=11.5.1 <12"
  },
  "scripts": {
    "start": "nx serve",
    "build": "nx run-many --target=build --all",
    "build:app": "nx build multi-level-push-menu-example",
    "prepare:pages": "node tools/scripts/prepare-pages.mjs",
    "build:lib": "nx build ngx-multi-level-push-menu",
    "build:libs": "nx run-many --target=build --projects=tag:lib",
    "build:apps": "nx run-many --target=build --projects=tag:app",
    "test": "nx run-many --target=test --all",
    "test:app": "nx test multi-level-push-menu-example",
    "test:lib": "nx test ngx-multi-level-push-menu",
    "test:libs": "nx run-many --target=test --projects=tag:lib",
    "test:apps": "nx run-many --target=test --projects=tag:app",
    "test:ci": "nx run-many --target=test --all -- --watch=false --bail --no-progress --progress=false",
    "lint": "nx run-many --target=lint --all && eslint tools/scripts commitlint.config.mjs release.config.mjs",
    "lint:fix": "nx run-many --target=lint --all --fix && eslint tools/scripts commitlint.config.mjs release.config.mjs --fix",
    "lint:affected": "nx affected --target=lint",
    "format": "nx format:check --all",
    "format:write": "nx format:write --all",
    "workspace-schematic": "nx workspace-schematic",
    "dep-graph": "nx dep-graph",
    "affected": "nx affected",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "security:check": "npm audit",
    "commitlint": "commitlint --last --verbose",
    "release": "semantic-release",
    "validate:automation": "node tools/scripts/validate-automation.mjs",
    "validate": "npm run format && npm run lint && npm run test:ci && npm run build:lib && npm run build:app && node tools/scripts/validate-package.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~20.3.26",
    "@angular/compiler": "~20.3.26",
    "@angular/core": "~20.3.26",
    "@angular/forms": "~20.3.26",
    "@angular/platform-browser": "~20.3.26",
    "@angular/platform-server": "~20.3.26",
    "@angular/router": "~20.3.26",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.3.32",
    "@angular-devkit/core": "~20.3.32",
    "@angular-devkit/schematics": "~20.3.32",
    "@angular-eslint/eslint-plugin": "~20.7.0",
    "@angular-eslint/eslint-plugin-template": "~20.7.0",
    "@angular-eslint/template-parser": "~20.7.0",
    "@angular/cli": "~20.3.32",
    "@angular/compiler-cli": "~20.3.26",
    "@angular/language-service": "~20.3.26",
    "@angular/platform-browser-dynamic": "~20.3.26",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/eslintrc": "~3.3.6",
    "@eslint/js": "~9.39.5",
    "@nx/angular": "~23.0.2",
    "@nx/cypress": "~23.0.2",
    "@nx/eslint": "~23.0.2",
    "@nx/eslint-plugin": "~23.0.2",
    "@nx/jest": "~23.0.2",
    "@schematics/angular": "~20.3.32",
    "@semantic-release/exec": "7.1.0",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.11.24",
    "@swc/helpers": "^0.5.11",
    "@types/jest": "^29.5.14",
    "@types/node": "~22.20.1",
    "@typescript-eslint/eslint-plugin": "~8.63.0",
    "@typescript-eslint/parser": "~8.63.0",
    "@typescript-eslint/utils": "~8.63.0",
    "angular-eslint": "~20.7.0",
    "autoprefixer": "^10.4.0",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "cypress": "~15.18.1",
    "eslint": "~9.39.5",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-cypress": "~6.4.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "~14.6.2",
    "ng-packagr": "~20.3.2",
    "nx": "~23.0.2",
    "playwright-webkit": "1.61.1",
    "postcss-preset-env": "^10.1.6",
    "prettier": "~3.9.5",
    "semantic-release": "25.0.6",
    "ts-jest": "~29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.40.0"
  },
  "overrides": {
    "koa": "^2.16.1"
  }
}
